<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>DBMS Digest — input feeds</title>
    <!-- Curated RSS/Atom feeds scanned each run, across all languages.
         Verified 2026-06-20 (browser-confirmed where noted):
           [ok]      fetches as plain XML with a normal fetch.
           [browser] live feed, but our plain fetch returns empty/blocked - read it with the
                     Claude-in-Chrome browser tools. Do NOT drop these; the source is good,
                     only the plain-fetch path fails. (Lobsters confirmed live via browser.)
         Maintain like the other source lists: add confirmed feeds, retire only truly dead ones. -->
  </head>
  <body>
    <outline text="Aggregators (English)">
      <outline type="rss" text="Planet PostgreSQL [ok]" xmlUrl="https://planet.postgresql.org/rss20.xml"/>
      <outline type="rss" text="Hacker News - postgres (>=20 pts) [ok]" xmlUrl="https://hnrss.org/newest?q=postgres&amp;points=20"/>
      <outline type="rss" text="Hacker News - database (>=50 pts) [ok]" xmlUrl="https://hnrss.org/newest?q=database&amp;points=50"/>
      <outline type="rss" text="Lobsters - databases tag [browser - confirmed live]" xmlUrl="https://lobste.rs/t/databases.rss"/>
    </outline>
    <outline text="Community (browser - .rss blocklisted/empty for plain fetch)">
      <outline type="rss" text="r/PostgreSQL [browser]" xmlUrl="https://www.reddit.com/r/PostgreSQL/.rss"/>
      <outline type="rss" text="r/databasedevelopment [browser]" xmlUrl="https://www.reddit.com/r/databasedevelopment/.rss"/>
    </outline>
    <outline text="Vendor blogs (English) - filter marketing hard">
      <!-- EDB = "The Postgres Builders Blog". Plain-fetch [ok] (verified 2026-06-28), but
           heavily marketing-skewed (AI/sovereignty/product PR); keep only genuine internals,
           HA, and migration write-ups per the anti-marketing rule. -->
      <outline type="rss" text="EDB blog [ok - marketing-heavy, filter]" xmlUrl="https://www.enterprisedb.com/blog/rss.xml"/>
    </outline>
    <outline text="Engines (English) - DuckDB / MariaDB family">
      <!-- All three plain-fetch [ok] (verified 2026-06-28). DuckDB = substantive engineering
           (releases, vectorized exec, Iceberg). MotherDuck + MariaDB.org mix engineering with
           sponsor/product PR - filter marketing. -->
      <outline type="rss" text="DuckDB blog [ok]" xmlUrl="https://duckdb.org/feed.xml"/>
      <outline type="rss" text="MotherDuck blog [ok - filter marketing]" xmlUrl="https://motherduck.com/rss.xml"/>
      <outline type="rss" text="MariaDB Foundation [ok - filter sponsor/PR]" xmlUrl="https://mariadb.org/feed/"/>
    </outline>
    <outline text="Research">
      <outline type="rss" text="arXiv cs.DB [ok]" xmlUrl="https://rss.arxiv.org/rss/cs.DB"/>
    </outline>
    <outline text="Russian [ru]">
      <!-- Scan Habr at HUB granularity, not the firehose: habr.com/ru/{news,articles,posts}/ is
           all-topic IT noise (~0 DB). These four DB hubs are dense + plain-fetch [ok] (2026-06-28).
           Articles cross-tagged across hubs (e.g. SQL+MySQL) will duplicate - dedupe on title/URL. -->
      <outline type="rss" text="Habr - PostgreSQL hub [ok]" xmlUrl="https://habr.com/ru/rss/hubs/postgresql/articles/?fl=ru"/>
      <outline type="rss" text="Habr - SQL hub [ok]" xmlUrl="https://habr.com/ru/rss/hubs/sql/articles/?fl=ru"/>
      <outline type="rss" text="Habr - MySQL hub [ok]" xmlUrl="https://habr.com/ru/rss/hubs/mysql/articles/?fl=ru"/>
      <outline type="rss" text="Habr - NoSQL hub [ok]" xmlUrl="https://habr.com/ru/rss/hubs/nosql/articles/?fl=ru"/>
    </outline>
    <outline text="Japanese [ja]">
      <outline type="rss" text="Qiita - PostgreSQL tag [ok]" xmlUrl="https://qiita.com/tags/postgresql/feed"/>
    </outline>
    <outline text="French [fr]">
      <outline type="rss" text="Dalibo blog [ok]" xmlUrl="https://blog.dalibo.com/feed.xml"/>
    </outline>
    <outline text="German [de]">
      <!-- /de/feed/ redirects to a non-feed page (/en/de/feed/); real German feed URL unresolved.
           Browse the /de/ blog with the browser to discover it, or rely on the EN Cybertec feed
           (same team, mostly mirrored content). -->
      <outline type="link" text="Cybertec (DE) [browser - discover feed; EN mirror exists]" htmlUrl="https://www.cybertec-postgresql.com/de/"/>
    </outline>
    <outline text="Chinese [zh] - browser-rendered; no clean RSS, heavy vendor-PR (filter hard)">
      <!-- Browser-confirmed 2026-06-20: modb.pro renders fine via Claude-in-Chrome.
           cn.pingcap.com never reaches document_idle (long-polling) - get_page_text times out;
           use read_page (screenshot) or modb instead. Chinese DB media is dense vendor PR
           (Dameng, Kingbase, GoldenDB, Highgo, ...) - drop it; mine OceanBase/TiDB/PolarDB
           research and genuine internals posts. -->
      <outline type="link" text="modb.pro - 墨天轮 DB news [browser - confirmed]" htmlUrl="https://www.modb.pro/dbNews"/>
      <outline type="link" text="PingCAP/TiDB CN blog [browser - slow; use read_page]" htmlUrl="https://cn.pingcap.com/blog/"/>
    </outline>
  </body>
</opml>
